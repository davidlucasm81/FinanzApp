rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper to check if user is an approved member (or becoming one in this batch)
    function isMember(familyId) {
      return request.auth != null && (
        exists(/databases/$(database)/documents/families/$(familyId)/members/$(request.auth.uid)) ||
        existsAfter(/databases/$(database)/documents/families/$(familyId)/members/$(request.auth.uid))
      );
    }

    // Helper to check if user is an admin or owner (or becoming one in this batch)
    function isAdmin(familyId) {
      return request.auth != null && (
        (exists(/databases/$(database)/documents/families/$(familyId)/members/$(request.auth.uid)) &&
         (get(/databases/$(database)/documents/families/$(familyId)/members/$(request.auth.uid)).data.role == 'admin' ||
          get(/databases/$(database)/documents/families/$(familyId)/members/$(request.auth.uid)).data.role == 'owner')) ||
        (existsAfter(/databases/$(database)/documents/families/$(familyId)/members/$(request.auth.uid)) &&
         (getAfter(/databases/$(database)/documents/families/$(familyId)/members/$(request.auth.uid)).data.role == 'admin' ||
          getAfter(/databases/$(database)/documents/families/$(familyId)/members/$(request.auth.uid)).data.role == 'owner'))
      );
    }

    // 1. User Rules
    match /users/{uid} {
      // A user may read and fully manage their own document
      allow read: if request.auth != null && request.auth.uid == uid;
      allow create: if request.auth != null && request.auth.uid == uid;
      allow delete: if request.auth != null && request.auth.uid == uid;

      // Allow update of own document
      allow update: if request.auth != null && request.auth.uid == uid
        // Additionally, allow an admin of a family to set *only* the `familyId` field
        // on a user's document when approving a join request. This avoids the need for
        // the admin to have full read/write access to other users' documents while
        // still permitting the specific update required by the approval flow.
        || (
          request.auth != null
          && request.resource.data.familyId is string
          // Ensure the update only changes the familyId field
          && request.resource.data.diff(resource.data).changedKeys().hasOnly(['familyId'])
          // Ensure the admin is indeed admin of the family being assigned
          && exists(/databases/$(database)/documents/families/$(request.resource.data.familyId)/members/$(request.auth.uid))
          && (get(/databases/$(database)/documents/families/$(request.resource.data.familyId)/members/$(request.auth.uid)).data.role == 'admin' ||
              get(/databases/$(database)/documents/families/$(request.resource.data.familyId)/members/$(request.auth.uid)).data.role == 'owner')
        )
        // Allow an admin/owner to clear (set to null) the familyId of a member they are
        // removing (kicking) from their own family.
        || (
          request.auth != null
          && request.resource.data.familyId == null
          && request.resource.data.diff(resource.data).changedKeys().hasOnly(['familyId'])
          && resource.data.familyId is string
          && exists(/databases/$(database)/documents/families/$(resource.data.familyId)/members/$(request.auth.uid))
          && (get(/databases/$(database)/documents/families/$(resource.data.familyId)/members/$(request.auth.uid)).data.role == 'admin' ||
              get(/databases/$(database)/documents/families/$(resource.data.familyId)/members/$(request.auth.uid)).data.role == 'owner')
        );
    }

    // 2. Families and Subcollections
    match /families/{familyId} {
      allow create: if request.auth != null;
      allow read: if request.auth != null;
      allow update, delete: if isAdmin(familyId);

      // Members
      match /members/{memberId} {
        allow read: if isMember(familyId);

        // Split write into create, update, delete for finer control
        allow create: if isAdmin(familyId) || (request.auth != null && request.auth.uid == memberId);

        allow update: if isAdmin(familyId) || (request.auth != null && request.auth.uid == memberId);

        allow delete: if isAdmin(familyId) || (request.auth != null && request.auth.uid == memberId);
      }

      // Invitations
      match /invitations/{invitationId} {
        allow read: if request.auth != null && (isMember(familyId) || request.auth.uid == resource.data.requestedByUid || request.auth.token.email == resource.data.targetEmail);

        // Anyone authenticated can request to join by code (code_request).
        // Only an admin/owner of the family can create an email invitation.
        allow create: if request.auth != null && (
          request.resource.data.type == 'code_request' ||
          (request.resource.data.type == 'email_invite' && isAdmin(familyId))
        );

        // Deleting/withdrawing an invitation: an admin can always remove it, the
        // original requester of a code_request can withdraw their own pending request,
        // and the target of an email invite can delete it (used to reject it).
        allow delete: if isAdmin(familyId) ||
                      (request.auth != null && request.auth.uid == resource.data.requestedByUid) ||
                      (request.auth != null && request.auth.token.email == resource.data.targetEmail);

        // Updating status: only an admin/owner may approve/reject a join request.
        // A requester may only withdraw (reject) their own code_request, never approve it.
        // The target of an email invite may only accept or reject their own invitation.
        allow update: if isAdmin(familyId) ||
                      (
                        request.auth != null
                        && request.auth.uid == resource.data.requestedByUid
                        && request.resource.data.status == 'rejected'
                        && request.resource.data.diff(resource.data).changedKeys().hasOnly(['status', 'resolvedAt', 'resolvedByUid'])
                      ) ||
                      (
                        request.auth != null
                        && request.auth.token.email == resource.data.targetEmail
                        && request.resource.data.status in ['accepted', 'rejected']
                        && request.resource.data.diff(resource.data).changedKeys().hasOnly(['status', 'resolvedAt', 'resolvedByUid'])
                      );
      }

      // Accounts: allow members to read and create accounts; only admins may perform
      // privileged updates (edit initialBalance, archive/delete).
      match /accounts/{accountId} {
        // Any approved member can read accounts
        allow read: if isMember(familyId);

        // Creation is allowed for members (including becoming-members in the same batch)
        allow create: if isMember(familyId);

        // Updates: allow admins to update any field. Allow regular members to update
        // only non-privileged fields (for example: name).
        allow update: if isAdmin(familyId) || (
          isMember(familyId)
          && request.resource.data.diff(resource.data).changedKeys().hasOnly(['name'])
        );

        // Deletion (physical) and archiving should be restricted to admins
        allow delete: if isAdmin(familyId);
      }

      match /categories/{categoryId} {
        allow read: if isMember(familyId);
        allow write: if isMember(familyId);
      }

      match /transactions/{transactionId} {
        allow read, write: if isMember(familyId);
      }
    }

    // 3. Collection Group rules
    match /{path=**}/invitations/{invitationId} {
      allow read: if request.auth != null && (
        request.auth.token.email == resource.data.targetEmail ||
        request.auth.uid == resource.data.requestedByUid
      );
    }
  }
}
