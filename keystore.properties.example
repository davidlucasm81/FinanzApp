# Copia este fichero como "keystore.properties" en la RAÍZ del proyecto
# (mismo nivel que settings.gradle, NO dentro de app/) y rellena tus valores
# reales. "keystore.properties" está en .gitignore y nunca debe subirse.
#
# El .jks/.keystore referenciado en storeFile tampoco debe subirse al repo:
# guárdalo fuera del proyecto (o en una carpeta local ignorada) y haz copia
# de seguridad en un gestor de contraseñas / almacenamiento seguro aparte.
# Si pierdes este keystore, NO podrás volver a publicar actualizaciones de
# la misma app en Google Play con el mismo applicationId: tendrías que
# publicarla como app nueva.

storeFile=/ruta/absoluta/fuera/del/repo/finanzapp-release.jks
storePassword=CAMBIA_ESTA_CONTRASENA
keyAlias=finanzapp
keyPassword=CAMBIA_ESTA_CONTRASENA
